{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "lastSeen": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "subscriptions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email"]
    },
    "Room": {
      "title": "Room",
      "description": "A watch party room",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "hostId": { "type": "string" },
        "hostName": { "type": "string" },
        "thumbnail": { "type": "string" },
        "type": { "type": "string", "enum": ["movie", "gaming", "youtube", "netflix", "disney", "prime", "hulu", "hbo", "twitch", "crunchyroll"] },
        "platform": { "type": "string" },
        "participantsCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "currentMedia": { "type": "string" },
        "playbackState": { "type": "string", "enum": ["playing", "paused"] },
        "currentTime": { "type": "number" },
        "videoUrl": { "type": "string" },
        "mutedUsers": { "type": "array", "items": { "type": "string" } },
        "kickedUsers": { "type": "array", "items": { "type": "string" } },
        "queue": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "videoUrl": { "type": "string" },
              "thumbnail": { "type": "string" }
            },
            "required": ["id", "title", "videoUrl"]
          }
        }
      },
      "required": ["title", "hostId"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message in a room",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderAvatar": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["message", "system"] }
      },
      "required": ["text", "senderId", "timestamp"]
    },
    "Activity": {
      "title": "Activity",
      "description": "User activity feed item",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "action": { "type": "string" },
        "target": { "type": "string" },
        "comment": { "type": "string" },
        "thumbnail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "target", "timestamp"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "An invitation to a watch party",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "toId": { "type": "string" },
        "roomId": { "type": "string" },
        "roomTitle": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["fromId", "toId", "roomId", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Active watch rooms"
    },
    "/rooms/{roomId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages for a room"
    },
    "/activity/{activityId}": {
      "schema": "Activity",
      "description": "Global activity feed"
    },
    "/invitations/{invitationId}": {
      "schema": "Invitation",
      "description": "User invitations"
    }
  }
}
